# 全部設定都可選 — 沒設的話首次啟動會跳 Setup Wizard 在瀏覽器填。
# 設了的話環境變數 / .env 優先，wizard 只補空欄位。

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-image

# Optional：覆寫 render prompt（不設就用 config.py 預設值）
# RENDER_PROMPT=...
# RENDER_COMPOSITE_PROMPT=...

# Storage（容器內路徑；通常維持預設即可）
SOURCE_DIR=/app/storage/source_image
UPLOAD_DIR=/app/storage/upload_image
RESULT_DIR=/app/storage/result_image
HISTORY_FILE=/app/storage/history.jsonl

MAX_GEMINI_CONCURRENCY=2
RATE_LIMIT_PER_MIN=20

# 後台 (admin.html 用)。沒設會走 setup wizard。
# 想手動設：
#   產 hash:   python -c "import bcrypt; print(bcrypt.hashpw(b'your-password', bcrypt.gensalt()).decode())"
#   產 secret: python -c "import secrets; print(secrets.token_urlsafe(32))"
# ⚠ bcrypt hash 開頭的 $ 要單引號包起來，否則 docker-compose 會把 $XXX 當變數展開：
#   ADMIN_PASSWORD_HASH='$2b$12$...'
ADMIN_PASSWORD_HASH=
ADMIN_SESSION_SECRET=
ADMIN_SESSION_HOURS=8
