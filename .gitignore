# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/

# Secret / 設定（一定不能 commit）
.env

# 用戶資料（包含敏感的設計圖 / 訂單關聯，絕對不能上 git）
storage/source_image/*
storage/upload_image/*
storage/result_image/*
storage/order_image/*
storage/cart_image/*
storage/_state/*
# 但保留資料夾結構（每個 storage 子資料夾的 .gitkeep）
!storage/*/.gitkeep

# OS / IDE
.DS_Store
.vscode/
.idea/
*.swp
*.swo
